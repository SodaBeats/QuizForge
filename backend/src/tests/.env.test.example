# .env.test.example
# Copy this file to .env.test and fill in your values.
# NEVER use your dev or production database here.
# Tests insert and delete real rows.

# Your Neon test database — create a separate DB just for tests
DATABASE_URL=postgresql://username:password@ep-xxxx.neon.tech/quizforge_test?sslmode=require

JWT_SECRET=your_jwt_secret_here
REFRESH_TOKEN_SECRET=your_refresh_secret_here

# Tells Express not to require HTTPS for cookies (see login.route.ts)
NODE_ENV=test
